create table public.ia (
  id bigint generated by default as identity not null,
  gasto mensal text not null,
  crescimento anual text not null,
  constraint ia_pkey primary key (id),
  constraint ia_crescimento anual_key unique ("crescimento anual"),
  constraint ia_gasto mensal_key unique ("gasto mensal"),
  constraint ia_gasto mensal_fkey foreign KEY ("gasto mensal") references "paÍs" (nome)
) TABLESPACE pg_default;
